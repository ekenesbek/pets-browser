# Clawnet — Agent Configuration
# Copy to .env and fill in your values

# ─── Managed mode (subscription) ─────────────────────────────────────────────
# Agent auth token is generated on install and saved in ~/.clawnet/agent-credentials.json
CN_API_URL=https://api.clawpets.io/clawnet/v1
# CN_AGENT_TOKEN=CN1.<agentId>.<agentSecret>
# CN_AGENT_ID=
# CN_AGENT_SECRET=
# CN_AGENT_RECOVERY_CODE=

# ─── BYO mode (bring your own) ──────────────────────────────────────────────
# Proxy provider: decodo | brightdata | iproyal | nodemaven
# Only set these if you have your own proxy account.
# If CN_PROXY_USER/CN_PROXY_PASS are empty, managed mode is used automatically.
# CN_PROXY_PROVIDER=decodo
# CN_PROXY_USER=
# CN_PROXY_PASS=
CN_PROXY_COUNTRY=us
# CN_PROXY_SERVER=          # Full override: http://host:port
# CN_PROXY_SESSION=         # Sticky session port (Decodo: 10001-49999)
# CN_NO_PROXY=1             # Disable proxy entirely (local testing)
# CN_PROFILE=default        # Persistent profile name (set profile:null in code for ephemeral)
# CN_CHROMIUM_NO_SANDBOX=   # 1 force disable / 0 force enable (auto: disabled only in Docker)

# CAPTCHA solving (2captcha.com)
TWOCAPTCHA_KEY=
